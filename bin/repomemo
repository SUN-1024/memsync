#!/usr/bin/env bash
# repomemo — initialize and validate shared AI project memory in a repository
#
# Usage:
#   repomemo init [--force] [--target DIR]
#   repomemo check [--strict|--verify] [PATH]
#   repomemo upgrade [--fetch] [--target DIR]
#   repomemo --help
#   repomemo --version
#
# repomemo is tool-neutral. It generates a `.ai/` scaffold plus thin root
# adapters (`CLAUDE.md`, `AGENTS.md`, `opencode.md`) so any AI coding agent
# that respects any of these conventions sees the same project memory.

set -euo pipefail

VERSION="1.3.0"

# Resolve the script's own directory, following symlinks (e.g. from Homebrew).
resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [ -h "$src" ]; do
    local dir
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd -P "$(dirname "$src")" && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"
# Default template path: sibling `templates/` directory. The Homebrew formula
# rewrites this line at install time to point at the share directory.
TEMPLATE_DIR="$(dirname "$SCRIPT_DIR")/templates"

# All files produced by `repomemo init`, relative to the project root.
SCAFFOLD_FILES=(
  ".ai/README.md"
  ".ai/project.md"
  ".ai/architecture.md"
  ".ai/definition-of-done.md"
  ".ai/review-checklist.md"
  ".ai/memory.md"
  ".ai/handoff.md"
  "CLAUDE.md"
  "AGENTS.md"
  "opencode.md"
)

AI_FILES=(
  ".ai/README.md"
  ".ai/project.md"
  ".ai/architecture.md"
  ".ai/definition-of-done.md"
  ".ai/review-checklist.md"
  ".ai/memory.md"
  ".ai/handoff.md"
)

ROOT_ADAPTERS=(
  "CLAUDE.md"
  "AGENTS.md"
  "opencode.md"
)

usage() {
  cat <<EOF
repomemo ${VERSION} — shared AI project memory scaffold

USAGE
  repomemo init [--force] [--target DIR]
  repomemo check [--strict|--verify] [PATH]
  repomemo upgrade [--fetch] [--target DIR]
  repomemo --help
  repomemo --version

COMMANDS
  init     Generate the .ai/ scaffold and root adapters in DIR (default: cwd).
           Existing files are skipped. Use --force to overwrite them.
  check    Validate that PATH (default: cwd) contains a complete .ai/ scaffold.
           Exits non-zero if any required file is missing or empty.
           Use --strict to also verify adapter ordering and template sync.
           Use --verify to also check that the shared memory is actually
           being used (files customized, adapter instructions present).
  upgrade  Update root adapter files (CLAUDE.md, AGENTS.md, opencode.md) from
           the latest local templates. Use --fetch to pull the latest
           templates from the GitHub main branch first. .ai/ files are
           never touched.

OPTIONS
  --force         For init: overwrite existing files instead of skipping them.
  --target DIR    For init, upgrade: target directory (defaults to cwd).
  --fetch         For upgrade: pull latest templates from the GitHub main
                  branch before applying. Requires curl and tar.
  --strict        For check: verify root adapters and templates agree.
  --verify        For check: all of --strict, plus memory freshness and
                  adapter instruction checks.
  --help, -h      Show this message.
  --version, -v   Show the version number.

DOCS
  https://github.com/SUN-1024/repomemo
EOF
}

print_version() {
  echo "repomemo ${VERSION}"
}

err() {
  echo "repomemo: $*" >&2
}

# Resolve target directory; create it if missing.
prepare_target() {
  local target="$1"
  if [ -z "$target" ]; then
    err "internal: target directory not specified"
    exit 2
  fi
  mkdir -p "$target"
}

expected_ai_files() {
  printf "%s\n" "${AI_FILES[@]}"
}

extract_at_imports() {
  local path="$1"
  sed -n \
    -e 's/^[[:space:]]*@\.\/\(\.ai\/.*\)[[:space:]]*$/\1/p' \
    -e 's/^[[:space:]]*@\(\.ai\/.*\)[[:space:]]*$/\1/p' \
    "$path"
}

extract_agents_list() {
  local path="$1"
  sed -n 's/^[[:space:]]*[0-9][0-9]*\.[[:space:]]*`\(\.ai\/[^`]*\)`.*/\1/p' "$path"
}

strict_pass() {
  printf "PASS  %-30s %s\n" "$1" "$2"
}

strict_fail() {
  printf "FAIL  %-30s %s\n" "$1" "$2"
}

verify_pass() {
  printf "PASS  %-30s %s\n" "$1" "$2"
}

verify_fail() {
  printf "FAIL  %-30s %s\n" "$1" "$2"
}

check_expected_list() {
  local label="$1"
  local actual="$2"
  local expected="$3"

  if [ "$actual" = "$expected" ]; then
    strict_pass "$label" "matches .ai read order"
    return 0
  fi

  strict_fail "$label" "does not match .ai read order"
  echo "      expected:"
  printf "%s\n" "$expected" | sed 's/^/        /'
  echo "      actual:"
  if [ -n "$actual" ]; then
    printf "%s\n" "$actual" | sed 's/^/        /'
  else
    echo "        (none)"
  fi
  return 1
}

check_files_match() {
  local label="$1"
  local left="$2"
  local right="$3"

  if cmp -s "$left" "$right"; then
    strict_pass "$label" "matches"
    return 0
  fi

  strict_fail "$label" "differs"
  return 1
}

run_strict_checks() {
  local target="$1"
  local failures=0
  local expected
  expected="$(expected_ai_files)"

  local claude_imports opencode_imports agents_list
  claude_imports="$(extract_at_imports "$target/CLAUDE.md")"
  opencode_imports="$(extract_at_imports "$target/opencode.md")"
  agents_list="$(extract_agents_list "$target/AGENTS.md")"

  check_expected_list "CLAUDE.md imports" "$claude_imports" "$expected" \
    || failures=$((failures + 1))
  check_expected_list "opencode.md imports" "$opencode_imports" "$expected" \
    || failures=$((failures + 1))
  check_expected_list "AGENTS.md list" "$agents_list" "$expected" \
    || failures=$((failures + 1))

  check_files_match "CLAUDE/opencode" "$target/CLAUDE.md" "$target/opencode.md" \
    || failures=$((failures + 1))

  local templates_dir="$target/templates"
  if [ -d "$templates_dir" ]; then
    local expected_templates actual_templates
    expected_templates="$(printf "%s\n" "${SCAFFOLD_FILES[@]}" | sort)"
    actual_templates="$(cd "$templates_dir" && find . -type f | sed 's#^\./##' | sort)"

    if [ "$actual_templates" = "$expected_templates" ]; then
      strict_pass "templates file set" "matches SCAFFOLD_FILES"
    else
      strict_fail "templates file set" "does not match SCAFFOLD_FILES"
      echo "      expected:"
      printf "%s\n" "$expected_templates" | sed 's/^/        /'
      echo "      actual:"
      if [ -n "$actual_templates" ]; then
        printf "%s\n" "$actual_templates" | sed 's/^/        /'
      else
        echo "        (none)"
      fi
      failures=$((failures + 1))
    fi

    local adapter
    for adapter in "${ROOT_ADAPTERS[@]}"; do
      check_files_match "templates/$adapter" "$target/$adapter" "$templates_dir/$adapter" \
        || failures=$((failures + 1))
    done
  else
    strict_pass "templates/" "not present; skipped template sync checks"
  fi

  return "$failures"
}

run_verify_checks() {
  local target="$1"
  local failures=0
  local need_memory=0 need_handoff=0 need_adapter=0

  # .ai/memory.md must differ from the template — if it matches the
  # scaffold original, agents are not writing project knowledge here.
  if [ -f "$TEMPLATE_DIR/.ai/memory.md" ] && cmp -s "$TEMPLATE_DIR/.ai/memory.md" "$target/.ai/memory.md" 2>/dev/null; then
    verify_fail ".ai/memory.md" "unchanged from template — agents may be using private memory instead"
    failures=$((failures + 1))
    need_memory=1
  else
    verify_pass ".ai/memory.md" "contains project knowledge"
  fi

  # .ai/handoff.md must differ from the template — it must be updated
  # after every task per the write rules.
  if [ -f "$TEMPLATE_DIR/.ai/handoff.md" ] && cmp -s "$TEMPLATE_DIR/.ai/handoff.md" "$target/.ai/handoff.md" 2>/dev/null; then
    verify_fail ".ai/handoff.md" "unchanged from template — agents may not be updating it after tasks"
    failures=$((failures + 1))
    need_handoff=1
  else
    verify_pass ".ai/handoff.md" "has been updated"
  fi

  # Each root adapter must contain the instruction that routes project
  # knowledge to .ai/ instead of agent-private memory.
  local adapter
  for adapter in "${ROOT_ADAPTERS[@]}"; do
    if grep -qF "agent-private memory" "$target/$adapter" 2>/dev/null; then
      verify_pass "$adapter" "has no-private-memory instruction"
    else
      verify_fail "$adapter" "missing no-private-memory instruction — run: repomemo upgrade"
      failures=$((failures + 1))
      need_adapter=1
    fi
  done

  # Optional: warn if a Claude Code private memory directory exists for
  # this repo (projects/ subdirectory pattern). This is informational only.
  local cc_memory_dir="${HOME}/.claude/projects"
  if [ -d "$cc_memory_dir" ]; then
    echo
    echo "Note: Claude Code private memory directory found at ${cc_memory_dir}"
    echo "      Project knowledge should live in .ai/memory.md, not here."
  fi

  # Print actionable fix instructions when checks fail.
  if [ "$failures" -gt 0 ]; then
    echo
    echo "──────────────────────────────────────────────────────────"
    echo "Fix instructions for AI coding agents:"
    echo
    if [ "$need_memory" -eq 1 ]; then
      echo "  1. Inspect this repository (code, docs, config, git log) and write"
      echo "     stable project facts to .ai/memory.md. Include: conventions,"
      echo "     constraints, common pitfalls, external integrations — facts"
      echo "     that would save the next agent time. Replace the template"
      echo "     sections with real project knowledge."
      echo
    fi
    if [ "$need_handoff" -eq 1 ]; then
      echo "  2. Update .ai/handoff.md to reflect the current task. Overwrite"
      echo "     the template sections with: Latest task, Files changed,"
      echo "     Commands run, Checks performed, Current state, and"
      echo "     Unresolved unknowns."
      echo
    fi
    if [ "$need_adapter" -eq 1 ]; then
      echo "  3. Run: repomemo upgrade"
      echo "     This updates the root adapters with the no-private-memory"
      echo "     instruction so project knowledge stays in .ai/ files."
      echo
    fi
    echo "  Important: Do NOT re-run \"repomemo init\" to fix these issues."
      echo "  Edit the existing .ai/ files in place. Re-running init would"
      echo "  either skip them (no change) or with --force would overwrite"
      echo "  any customized content and destroy project knowledge."
      echo
      echo "After completing these steps, re-run: repomemo check --verify"
    echo "──────────────────────────────────────────────────────────"
  fi

  return "$failures"
}

cmd_init() {
  local force=0
  local target="."
  while [ $# -gt 0 ]; do
    case "$1" in
      --force)
        force=1
        shift
        ;;
      --target)
        if [ $# -lt 2 ]; then
          err "--target requires a directory argument"
          exit 2
        fi
        target="$2"
        shift 2
        ;;
      --target=*)
        target="${1#--target=}"
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option for init: $1"
        echo "Run 'repomemo --help' for usage." >&2
        exit 2
        ;;
    esac
  done

  if [ ! -d "$TEMPLATE_DIR" ]; then
    err "template directory not found at: $TEMPLATE_DIR"
    err "this build of repomemo is broken — please reinstall."
    exit 1
  fi

  prepare_target "$target"

  # Warn if .ai/ already exists — re-initializing can destroy customized content.
  if [ -d "$target/.ai" ] && [ "$force" -eq 0 ]; then
    echo "Note: .ai/ already exists in $target"
    echo "      Files that already exist will be skipped."
    echo "      Files that don't exist yet will be created from templates."
    echo "      Do NOT use --force unless you want to overwrite ALL .ai/ files"
    echo "      and lose any project-specific customizations."
    echo
  fi

  if [ -d "$target/.ai" ] && [ "$force" -eq 1 ]; then
    echo "WARNING: --force will overwrite ALL .ai/ files with templates."
    echo "         Any project-specific knowledge in .ai/memory.md,"
    echo "         .ai/handoff.md, .ai/project.md, etc. will be LOST."
    echo
  fi

  local created=0 skipped=0 overwritten=0 missing_template=0
  for rel in "${SCAFFOLD_FILES[@]}"; do
    local src="$TEMPLATE_DIR/$rel"
    local dst="$target/$rel"

    if [ ! -f "$src" ]; then
      err "template missing: $rel (looked at $src)"
      missing_template=$((missing_template + 1))
      continue
    fi

    mkdir -p "$(dirname "$dst")"

    if [ -e "$dst" ]; then
      if [ "$force" -eq 1 ]; then
        cp "$src" "$dst"
        echo "overwrote $rel"
        overwritten=$((overwritten + 1))
      else
        echo "skipped   $rel (already exists)"
        skipped=$((skipped + 1))
      fi
    else
      cp "$src" "$dst"
      echo "created   $rel"
      created=$((created + 1))
    fi
  done

  echo
  echo "repomemo init: ${created} created, ${overwritten} overwritten, ${skipped} skipped"
  if [ "$missing_template" -gt 0 ]; then
    err "${missing_template} template file(s) missing — installation may be incomplete."
    exit 1
  fi

  if [ "$skipped" -gt 0 ] && [ "$force" -eq 0 ]; then
    echo
    echo "Some files were left untouched. Re-run with --force to overwrite them."
  fi
}

cmd_check() {
  local target="."
  local target_set=0
  local strict=0
  local verify=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --strict)
        strict=1
        shift
        ;;
      --verify)
        verify=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      -*)
        err "unknown option for check: $1"
        echo "Run 'repomemo --help' for usage." >&2
        exit 2
        ;;
      *)
        if [ "$target_set" -eq 1 ]; then
          err "check accepts at most one path"
          echo "Run 'repomemo --help' for usage." >&2
          exit 2
        fi
        target="$1"
        target_set=1
        shift
        ;;
    esac
  done

  if [ ! -d "$target" ]; then
    err "path does not exist or is not a directory: $target"
    exit 1
  fi

  local fail=0
  for rel in "${SCAFFOLD_FILES[@]}"; do
    local path="$target/$rel"
    if [ ! -f "$path" ]; then
      printf "FAIL  %-30s missing\n" "$rel"
      fail=$((fail + 1))
    elif [ ! -s "$path" ]; then
      printf "FAIL  %-30s empty\n" "$rel"
      fail=$((fail + 1))
    else
      printf "PASS  %-30s\n" "$rel"
    fi
  done

  # --verify implies --strict.
  if [ "$verify" -eq 1 ]; then
    strict=1
  fi

  if [ "$strict" -eq 1 ]; then
    echo
    echo "Strict checks:"
    if [ "$fail" -gt 0 ]; then
      strict_fail "strict prerequisites" "base scaffold is incomplete"
      fail=$((fail + 1))
    else
      local strict_failures=0
      run_strict_checks "$target" || strict_failures=$?
      fail=$((fail + strict_failures))
    fi
  fi

  if [ "$verify" -eq 1 ] && [ "$fail" -eq 0 ]; then
    echo
    echo "Memory verification:"
    local verify_failures=0
    run_verify_checks "$target" || verify_failures=$?
    fail=$((fail + verify_failures))
  fi

  echo
  if [ "$fail" -eq 0 ]; then
    if [ "$verify" -eq 1 ]; then
      echo "repomemo check: OK (${#SCAFFOLD_FILES[@]} files, strict, verify)"
    elif [ "$strict" -eq 1 ]; then
      echo "repomemo check: OK (${#SCAFFOLD_FILES[@]} files, strict)"
    else
      echo "repomemo check: OK (${#SCAFFOLD_FILES[@]} files)"
    fi
    return 0
  fi

  echo "repomemo check: ${fail} problem(s) in $target"
  return 1
}

cmd_upgrade() {
  local target="."
  local fetch=0
  local fetch_dir=""
  local template_dir="$TEMPLATE_DIR"

  while [ $# -gt 0 ]; do
    case "$1" in
      --target)
        if [ $# -lt 2 ]; then
          err "--target requires a directory argument"
          exit 2
        fi
        target="$2"
        shift 2
        ;;
      --target=*)
        target="${1#--target=}"
        shift
        ;;
      --fetch)
        fetch=1
        shift
        ;;
      -h|--help)
        usage
        return 0
        ;;
      *)
        err "unknown option for upgrade: $1"
        echo "Run 'repomemo --help' for usage." >&2
        exit 2
        ;;
    esac
  done

  # --fetch: download latest templates from GitHub before upgrading.
  if [ "$fetch" -eq 1 ]; then
    if ! command -v curl >/dev/null 2>&1; then
      err "--fetch requires curl (not found on PATH)"
      exit 1
    fi
    if ! command -v tar >/dev/null 2>&1; then
      err "--fetch requires tar (not found on PATH)"
      exit 1
    fi

    fetch_dir="$(mktemp -d -t repomemo-fetch.XXXXXX)"

    echo "Fetching latest templates from GitHub (main branch)..."
    if ! curl -fsSL "https://github.com/SUN-1024/repomemo/archive/refs/heads/main.tar.gz" | tar -xz --strip-components=1 -C "$fetch_dir" 2>/dev/null; then
      err "failed to download or extract main branch tarball"
      rm -rf "$fetch_dir"
      exit 1
    fi

    if [ ! -d "$fetch_dir/templates" ]; then
      err "downloaded archive does not contain templates/ directory"
      rm -rf "$fetch_dir"
      exit 1
    fi

    template_dir="$fetch_dir/templates"
  fi

  if [ ! -d "$template_dir" ]; then
    err "template directory not found at: $template_dir"
    err "this build of repomemo is broken — please reinstall."
    if [ -n "$fetch_dir" ]; then rm -rf "$fetch_dir"; fi
    exit 1
  fi

  if [ ! -d "$target" ]; then
    err "path does not exist or is not a directory: $target"
    if [ -n "$fetch_dir" ]; then rm -rf "$fetch_dir"; fi
    exit 1
  fi

  local updated=0 uptodate=0 missing_template=0
  for rel in "${ROOT_ADAPTERS[@]}"; do
    local src="$template_dir/$rel"
    local dst="$target/$rel"

    if [ ! -f "$src" ]; then
      err "template missing: $rel (looked at $src)"
      missing_template=$((missing_template + 1))
      continue
    fi

    if [ -f "$dst" ]; then
      if cmp -s "$src" "$dst"; then
        echo "up-to-date $rel"
        uptodate=$((uptodate + 1))
      else
        cp "$src" "$dst"
        echo "updated    $rel"
        updated=$((updated + 1))
      fi
    else
      cp "$src" "$dst"
      echo "created    $rel (was missing)"
      updated=$((updated + 1))
    fi
  done

  echo
  echo "repomemo upgrade: ${updated} updated, ${uptodate} up-to-date"
  if [ "$missing_template" -gt 0 ]; then
    err "${missing_template} template file(s) missing — installation may be incomplete."
    if [ -n "$fetch_dir" ]; then rm -rf "$fetch_dir"; fi
    exit 1
  fi

  if [ -n "$fetch_dir" ]; then
    rm -rf "$fetch_dir"
  fi
}

main() {
  if [ $# -eq 0 ]; then
    usage
    exit 0
  fi

  case "$1" in
    init)
      shift
      cmd_init "$@"
      ;;
    check)
      shift
      cmd_check "$@"
      ;;
    upgrade)
      shift
      cmd_upgrade "$@"
      ;;
    -h|--help|help)
      usage
      ;;
    -v|--version|version)
      print_version
      ;;
    *)
      err "unknown command: $1"
      echo "Run 'repomemo --help' for usage." >&2
      exit 2
      ;;
  esac
}

main "$@"
